{
  "name": "alicedcodes.github.io",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -b && vite build && cp dist/index.html dist/404.html",
    "deploy": "gh-pages -d dist",
    "dev": "vite",
    "format": "oxfmt src --write",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "predeploy": "npm run build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@icons-pack/react-simple-icons": "^13.13.0",
    "clsx": "^2.1.1",
    "lucide-react": "^1.23.0",
    "modern-normalize": "^3.0.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1",
    "usehooks-ts": "^3.1.1"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "gh-pages": "^6.3.0",
    "oxfmt": "^0.57.0",
    "oxlint": "^1.71.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.1"
  }
}
